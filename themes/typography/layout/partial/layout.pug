doctype
html(lang="zh-CN")
    head
        include head

    body(class=`${page.path.includes('about/') ? 'about-page' : ''} ${is_post() ? 'post-page' : ''} ${page.path === 'index.html' ? 'home' : ''}`)
        div#stage.container
            div.row
                div.mobile-site-title.visible-xs
                    h1.site-title-large
                        a.a-title(href=theme.personal_site)= theme.title_primary
                    h3.site-title-small
                        a.a-title(href=theme.personal_site)= theme.title_secondary
                if is_post()
                    .toc-container.toc-pc
                        .toc-content
                include sidebar
                div#main-container.col-sm-9.col-xs-12.main-container
                    if page.archive
                        .archive-timeline
                            .timeline-content
                    block content
                    div.visible-xs.site-bottom-footer
                        include footer


        script(src= url_for('js/jquery-3.1.0.min.js'))
        script(src= url_for('js/bootstrap.min.js'))
        script(src= url_for('js/jquery-migrate-1.2.1.min.js'))
        script(src= url_for('js/jquery.appear.js'))
        script(src= url_for('js/google-analytics.js'))
        script(src= url_for('js/typography.js'))
        //- Mermaid：须在 prism-language-label 之前执行，避免对已替换节点打标签
        if is_post()
            script(src="https://cdn.jsdelivr.net/npm/mermaid@11.6.0/dist/mermaid.min.js")
            script(src= url_for('js/mermaid-init.js'))
        //- 代码块语言标签脚本
        script(src= url_for('js/prism-language-label.js'))
        if is_post()
            script(src= url_for('js/toc.js'))
        if page.archive
            script(src= url_for('js/archive-timeline.js'))
        if page.category
            script(src= url_for('js/category-timeline.js'))

